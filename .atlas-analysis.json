  "keyFeatures": [
    "Context-aware formatting based on active application (VS Code, Slack, Outlook, etc.)",
    "Global hotkey recording with Auto, Toggle, and Push-to-Talk modes (Ctrl+Shift+K)",
    "Select-to-Transform: select text, speak a transformation, auto-replace",
    "Groq Whisper speech-to-text with optional LLM post-processing",
    "App Profiles with per-app language overrides for multilingual workflows",
    "Log Mode: voice-triggered markdown note-taking with timestamps",
    "Lightweight ~15MB bundle using Rust/Tauri instead of Electron",
    "Local-first architecture: audio processed in-memory, never stored on disk",
    "Google OAuth authentication with OS keyring secure credential storage",
    "Auto-paste transcribed text into the active application via clipboard simulation"
  ],
  "publicApiSurface": [
    "get_store_value(key: string) -> string | null",
