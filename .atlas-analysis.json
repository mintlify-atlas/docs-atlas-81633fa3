    "open_settings_window() -> void",
    "transcription_complete(text: string) -> void",
    "copy_selected_text() -> string | null",
    "register_escape_shortcut() -> void",
    "unregister_escape_shortcut() -> void",
    "search_installed_apps(query: string) -> InstalledApp[]",
    "get_installed_popular_apps() -> InstalledApp[]",
    "start_google_login() -> void",
    "get_auth_state() -> AuthState",
    "get_user_info() -> UserInfo | null",
    "logout() -> void",
    "append_to_file(path: string, content: string) -> void",
